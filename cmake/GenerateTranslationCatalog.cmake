function(sonarp_generate_translation_catalog)
    set(options "")
    set(oneValueArgs OUTPUT_HEADER BASE_NAME SOURCE_LANGUAGE)
    set(multiValueArgs TS_FILES)
    cmake_parse_arguments(ARG "${options}" "${oneValueArgs}" "${multiValueArgs}" ${ARGN})

    if(NOT ARG_OUTPUT_HEADER)
        message(FATAL_ERROR "sonarp_generate_translation_catalog: OUTPUT_HEADER is required")
    endif()
    if(NOT ARG_BASE_NAME)
        set(ARG_BASE_NAME "${PROJECT_NAME}")
    endif()
    if(NOT ARG_SOURCE_LANGUAGE)
        set(ARG_SOURCE_LANGUAGE "en")
    endif()

    set(_locales "")
    foreach(_ts_file ${ARG_TS_FILES})
        get_filename_component(_ts_name "${_ts_file}" NAME_WE)
        if(NOT _ts_name MATCHES "^${ARG_BASE_NAME}_(.+)$")
            message(WARNING "Translation file '${_ts_file}' does not match ${ARG_BASE_NAME}_<locale>.ts")
            continue()
        endif()
        list(APPEND _locales "${CMAKE_MATCH_1}")
    endforeach()
    list(REMOVE_DUPLICATES _locales)
    list(SORT _locales)

    set(_header_content "#pragma once\n\n#include <QString>\n#include <QStringList>\n\nnamespace SonarpTranslationCatalog {\n\ninline QString baseName()\n{\n    return QStringLiteral(\"${ARG_BASE_NAME}\");\n}\n\ninline QString sourceLanguage()\n{\n    return QStringLiteral(\"${ARG_SOURCE_LANGUAGE}\");\n}\n\ninline QStringList locales()\n{\n    return {\n")
    foreach(_locale ${_locales})
        string(APPEND _header_content "        QStringLiteral(\"${_locale}\"),\n")
    endforeach()
    string(APPEND _header_content "    };\n}\n\n} // namespace SonarpTranslationCatalog\n")

    get_filename_component(_output_dir "${ARG_OUTPUT_HEADER}" DIRECTORY)
    file(MAKE_DIRECTORY "${_output_dir}")
    file(WRITE "${ARG_OUTPUT_HEADER}" "${_header_content}")
endfunction()
